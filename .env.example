# InferAPI configuration
INFERAPI_HOST=0.0.0.0
INFERAPI_PORT=8000

# API keys (comma-separated, generate your own)
INFERAPI_API_KEYS=sk-inferapi-test-key-001

# Backends
VLLM_BASE_URL=http://localhost:8001
OLLAMA_BASE_URL=http://localhost:11434

# Model aliases (format: alias:backend:local_model_name)
# Examples:
#   gpt-4:vllm:meta-llama/Llama-3-70B
#   gpt-3.5-turbo:ollama:llama3:8b
#   claude-3-opus:vllm:mistralai/Mixtral-8x22B
INFERAPI_MODEL_ALIASES=gpt-4:vllm:meta-llama/Llama-3-70B,gpt-3.5-turbo:ollama:llama3:8b

# Rate limiting (requests per minute per API key)
INFERAPI_RATE_LIMIT=60

# Logging
INFERAPI_LOG_LEVEL=info
